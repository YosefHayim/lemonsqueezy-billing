{
  "name": "lemonsqueezy-billing",
  "version": "1.0.23",
  "description": "The missing billing layer for Lemon Squeezy. Auto-discover, checkout, webhooks — one function.",
  "author": "Yosef Hayim Sabag <yosefhayim@proton.me>",
  "homepage": "https://github.com/yosefhayim/lemonsqueezy-billing#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yosefhayim/lemonsqueezy-billing.git"
  },
  "bugs": {
    "url": "https://github.com/yosefhayim/lemonsqueezy-billing/issues"
  },
  "keywords": [
    "lemonsqueezy",
    "lemon-squeezy",
    "billing",
    "payments",
    "checkout",
    "webhooks",
    "subscriptions",
    "saas",
    "typescript",
    "ecommerce",
    "api",
    "sdk"
  ],
  "sideEffects": false,
  "llms": "https://raw.githubusercontent.com/yosefhayim/lemonsqueezy-billing/main/llms.txt",
  "type": "module",
  "main": "dist/src/core/index.js",
  "types": "dist/src/core/index.d.ts",
  "bin": {
    "lemonsqueezy-billing": "dist/src/cli/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/core/index.d.ts",
      "import": "./dist/src/core/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "validate": "pnpm build && tsx scripts/validate.ts",
    "cli-test": "tsx scripts/cli-test.ts",
    "cli-test:sandbox": "tsx scripts/cli-test.ts --sandbox",
    "cli-test:live": "tsx scripts/cli-test.ts --live",
    "wizard": "tsx src/wizard.ts"
  },
  "peerDependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^3.2.0",
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@lemonsqueezy/lemonsqueezy.js": "^3.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "chalk": "^5.3.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "husky": "^9.1.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "MIT"
}
