# Lemon Squeezy API Keys
# Use test mode API key for sandbox testing (starts with ls_test_)
LS_TEST_API_KEY=ls_test_your_test_api_key_here
# Use live mode API key for production testing (starts with ls_live_)
LS_LIVE_API_KEY=ls_live_your_live_api_key_here

# Webhook Secret (required for webhook verification)
# Generate this in your Lemon Squeezy dashboard under Webhooks
LS_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Test customer email for customer lookup tests
LS_TEST_EMAIL=test@example.com

# Optional: License key for license validation tests
LS_TEST_LICENSE_KEY=your_test_license_key_here

# Optional: Subscription ID for subscription management tests
LS_TEST_SUBSCRIPTION_ID=your_test_subscription_id_here

# Optional: Public webhook URL for webhook management tests
# Required for Phase 4 E2E tests (use ngrok or similar for local testing)
LS_TEST_WEBHOOK_URL=https://your-public-url.com/webhook